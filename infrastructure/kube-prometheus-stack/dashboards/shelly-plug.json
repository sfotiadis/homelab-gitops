                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"shelly\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_field\"] == \"power_watts\")\n  |> integral(unit: 1h)\n  |> map(fn: (r) => ({ r with _value: r._value / 1000.0 * 0.3082 }))   "
