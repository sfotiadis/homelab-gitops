                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "afnu04q6hgge8e"
                    },
                    "group": "shelly-timescaledb",
                    "kind": "DataQuery",
                    "spec": {
                      "dataset": "shelly",
                      "editorMode": "code",
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT\n  SUM(energy_kwh) * 0.38 AS cost\nFROM (\n  SELECT\n    time_bucket('1 minute', time) AS bucket,\n    AVG(power_watts) * 1.0 / 60 / 1000 AS energy_kwh\n  FROM shelly\n  WHERE $__timeFilter(time)\n  GROUP BY 1\n) t;",
                      "sql": {
                        "columns": [
                          {
                            "parameters": [],
                            "type": "function"
                          }
                        ],
                        "groupBy": [
                          {
                            "property": {
                              "type": "string"
                            },
                            "type": "groupBy"
                          }
                        ],
                        "limit": 50
                      }
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
